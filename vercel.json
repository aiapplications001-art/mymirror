{
  "rewrites": [
    {
      "source": "/scan/:path*",
      "destination": "https://face3layerscanner.onrender.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*).(jpg|png|webp|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}